# Template file for 'ananicy-cpp'
pkgname=ananicy-cpp
version=1.2.0
revision=1
wrksrc="${pkgname}-master"
build_style=cmake
configure_args="-DCMAKE_BUILD_TYPE=Release -DENABLE_SYSTEMD=OFF -DCPM_USE_LOCAL_PACKAGES=ON"
hostmakedepends="cmake ninja pkg-config bpftool git"
makedepends="libbpf-devel json-c++"
short_desc="Community fork of Ananicy with performance improvements"
maintainer="Pablo G. Alba <pabloguti51@proton.me>"
license="GPL-3.0-or-later"
homepage="https://gitlab.com/ananicy-cpp/ananicy-cpp"
distfiles="https://gitlab.com/ananicy-cpp/ananicy-cpp/-/archive/master/ananicy-cpp-master.tar.gz"
checksum=b8833d523a9d7fb8a114dc7577c6ca41708e41e89bdd82508bc2e45443f72fe5
nocross=yes

# Crear usuario svlog para el logger de runit y su directorio de logs
system_accounts="svlog"
svlog_homedir="/var/log/ananicy-cpp"
make_dirs="/var/log/ananicy-cpp 0755 svlog svlog"

post_install() {
	# Eliminar el servicio systemd que viene en el build original
	rm -rf ${DESTDIR}/usr/lib/systemd
	rm -rf ${DESTDIR}/lib/systemd
	# Instalar el servicio runit
	vsv ananicy-cpp
}
