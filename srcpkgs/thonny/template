# Template file for 'thonny'
pkgname=thonny
version=5.0.0
revision=2
build_style=python3-module
hostmakedepends="python3-setuptools"
depends="python3-tkinter python3-jedi python3-pyserial python3-pylint
         python3-docutils python3-mypy python3-asttokens python3-send2trash
         python3-wheel"
short_desc="Python IDE for beginners"
maintainer="Pablo G. Alba <pabloguti51@proton.me>"
license="MIT"
homepage="https://thonny.org"
changelog="https://github.com/thonny/thonny/releases"
distfiles="https://github.com/thonny/thonny/archive/refs/tags/v${version}.tar.gz"
checksum=26645a0fd72ed2d41bc901ba72aa89b09c3b1ec70b16dbad82e8597582c7a462

do_install() {
    python3 setup.py install --root=${DESTDIR} --optimize=1
    
    vinstall ${FILESDIR}/thonny.desktop 644 usr/share/applications
    
    vinstall "${wrksrc}/thonny/res/thonny.png" 644 usr/share/pixmaps
}
