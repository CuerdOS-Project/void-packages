# Template file for 'librewolf'
pkgname=librewolf
version=151.0.3
revision=1
_appimage_version="151.0.3-1"
wrksrc="files"
short_desc="Community-maintained fork of Firefox, focused on privacy and security"
maintainer="Pablo G. Alba <pabloguti51@proton.me>"
license="MPL-2.0, GPL-2.0-or-later, LGPL-2.1-or-later"
homepage="https://librewolf.net"
distfiles="https://gitlab.com/api/v4/projects/24386000/packages/generic/librewolf/${_appimage_version}/LibreWolf.x86_64.AppImage"
checksum=4412cff89643a34b1b8a70dd765ba594f0a27a7248b54c9948649130cce05d3e
depends="libgomp desktop-file-utils hicolor-icon-theme shared-mime-info"

do_extract() {
    chmod +x "${XBPS_SRCDISTDIR}/${pkgname}-${version}/LibreWolf.x86_64.AppImage"
    "${XBPS_SRCDISTDIR}/${pkgname}-${version}/LibreWolf.x86_64.AppImage" --appimage-extract
    mv squashfs-root files
}

do_install() {
    mkdir -p "${DESTDIR}/opt/librewolf"
    
    cp -a "${wrksrc}"/* "${DESTDIR}/opt/librewolf/"
    
    chmod 755 "${DESTDIR}/opt/librewolf/files/librewolf"
    
    mkdir -p "${DESTDIR}/usr/bin"
    ln -sf /opt/librewolf/files/librewolf "${DESTDIR}/usr/bin/librewolf"
    
    vinstall "${FILESDIR}/librewolf.desktop" 644 usr/share/applications
    
    for size in 16 32 48 64 128; do
        if [ -f "${wrksrc}/usr/share/icons/hicolor/${size}x${size}/apps/librewolf.png" ]; then
            vinstall "${wrksrc}/usr/share/icons/hicolor/${size}x${size}/apps/librewolf.png" 644 \
                usr/share/icons/hicolor/${size}x${size}/apps
        fi
    done
    
    if [ -f "${wrksrc}/usr/share/icons/hicolor/scalable/apps/librewolf.svg" ]; then
        vinstall "${wrksrc}/usr/share/icons/hicolor/scalable/apps/librewolf.svg" 644 \
            usr/share/icons/hicolor/scalable/apps
    fi
}
