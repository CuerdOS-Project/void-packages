# Template file for 'brave-browser'
pkgname=brave-browser
version=1.91.180
revision=1
archs="x86_64 aarch64"
short_desc="Web browser that blocks ads and trackers by default (binary release)"
maintainer="Pablo G. Alba <pabloguti51@proton.me>"
license="MPL-2.0, BSD-3-Clause, custom:chromium"
homepage="https://brave.com"
distfiles="https://github.com/brave/brave-browser/releases/download/v${version}/brave-browser-${version}-linux-amd64.zip"
checksum=6d5349a7c02043720b9bd655eddea85691813a309bc474485211dd66730d5e5f
nocross=yes
nopie=yes

depends="alsa-lib gtk+3 libXScrnSaver nss"
# optdepends no existe en xbps-src; se documenta aquí como referencia:
# cups: Printer support
# libgnome-keyring: GNOME keyring support
# libnotify: Native notification support

# No extraer automáticamente el zip
noextract="brave-browser-${version}-linux-amd64.zip brave-browser-${version}-linux-arm64.zip"

do_extract() {
	mkdir -p ${wrksrc}/brave
	case "$XBPS_TARGET_MACHINE" in
		x86_64)  local _zip="brave-browser-${version}-linux-amd64.zip" ;;
		aarch64) local _zip="brave-browser-${version}-linux-arm64.zip" ;;
	esac
	bsdtar -xf "${XBPS_SRCDISTDIR}/${pkgname}-${version}/${_zip}" -C ${wrksrc}/brave
	chmod +x ${wrksrc}/brave/brave
}

do_install() {
	# Instalar binarios en /opt
	vmkdir opt/${pkgname}
	bcopy() { cp -a ${wrksrc}/brave/. ${DESTDIR}/opt/${pkgname}/; }
	bcopy

	# SUID sandbox para firejail
	chmod 4755 ${DESTDIR}/opt/${pkgname}/chrome-sandbox

	# Wrapper script en /usr/bin
	vinstall ${FILESDIR}/brave-bin.sh 755 usr/bin brave

	# .desktop
	vinstall ${FILESDIR}/brave-browser.desktop 644 usr/share/applications

	# Licencia
	vlicense ${wrksrc}/brave/LICENSE

	# Iconos
	for size in 16 24 32 48 64 128 256; do
		vinstall ${DESTDIR}/opt/${pkgname}/product_logo_${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps brave-desktop.png
	done
}
